{
  "name": "@finch/plugin-git-branch",
  "version": "1.0.0",
  "description": "Switch Git branches from the Finch Composer toolbar.",
  "author": {
    "name": "Finch Team",
    "url": "https://finchwork.app"
  },
  "homepage": "https://finchwork.app",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "finch": {
    "manifestVersion": 1,
    "id": "git-branch",
    "displayName": {
      "en-US": "Git Branch",
      "zh-CN": "Git 分支"
    },
    "description": {
      "en-US": "Switch Git branches from the Composer toolbar. Shows the current branch name as a badge and lets you check out any local branch.",
      "zh-CN": "在 Composer 工具栏显示当前 Git 分支，并可切换本地分支。"
    },
    "main": "dist/index.js",
    "activationEvents": ["onStartup"],
    "pluginType": "official",
    "categories": ["developer-tools", "composer-action"],
    "privacyPolicyUrl": "https://finchwork.app/privacy",
    "termsOfServiceUrl": "https://finchwork.app/terms",
    "contributes": {
      "composerActions": [
        {
          "id": "git-branch",
          "icon": "GitBranch",
          "tooltip": "Switch Git branch"
        }
      ],
      "skills": false
    },
    "permissions": {
      "filesystem": "none",
      "network": false,
      "shell": true
    }
  }
}
